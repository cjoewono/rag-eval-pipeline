# 1. LLM Provider APIs
# --------------------
OPENAI_API_KEY=sk-proj-placeholder_key_here
ANTHROPIC_API_KEY=sk-ant-placeholder_key_here

# 2. Vector Database Configuration
# --------------------------------
# For local dev, we default to ChromaDB. 
# For production-like, you might swap to Qdrant.
VECTOR_DB_TYPE=chromadb
CHROMA_PERSIST_DIRECTORY=./chroma_db
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=placeholder_if_using_cloud

# 3. Evaluation (DeepEval)
# ------------------------
# Set to 'true' to enable tracing and logging to DeepEval platform
DEEPEVAL_TELEMETRY_OPT_OUT=false

# 4. Observability & API
# ----------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
